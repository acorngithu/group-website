---
// src/pages/research.astro — pillar landing
import BaseLayout from "../layouts/BaseLayout.astro";
import PillarFigure from "../components/PillarFigure.astro";
import LagrangeSurface from "../components/LagrangeSurface.astro";
import { research } from "../data/research";
import { ui } from "../data/i18n";
import Bi from "../components/Bi.astro";

const BASE = import.meta.env.BASE_URL.replace(/\/+$/, "");
const link = (slug: string) => `${BASE}/research/${slug}`;

// Each card's right-hand visual: a still frame (img) or a live animation (anim).
const VISUAL: Record<string, { img?: string; fit?: string; anim?: string; trojan?: boolean }> = {
  "reconfigurable-photonics": { anim: "reconfigurablePixels" },
  "optical-thermodynamic-computing": { img: BASE + "/research/figures/thermal-chip.png", fit: "cover" },
  "analog-neural-networks": { img: BASE + "/research/card-neural.png", fit: "cover" },
  "complex-light-dynamics": { trojan: true },
};
---

<BaseLayout title="Research — Wu Lab" description="Our research pillars.">
  <main class="wrap">
    <header class="masthead">
      <div class="eyebrow"><Bi en={ui.research.eyebrow.en} zh={ui.research.eyebrow.zh} /></div>
      <h1><Bi en={ui.research.title.en} zh={ui.research.title.zh} /></h1>
      <p><Bi en={ui.research.lead.en} zh={ui.research.lead.zh} /></p>
    </header>

    <div class="pillars">
      {
        research.map((pillar) => {
          const v = VISUAL[pillar.slug] ?? {};
          return (
            <a class="pillar" href={link(pillar.slug)} aria-label={pillar.title}>
              <div class="pillar-body">
                <h2><Bi en={pillar.title} zh={pillar.titleZh} /></h2>
                <p><Bi en={pillar.tagline} zh={pillar.taglineZh} /></p>
                <span class="pillar-go"><Bi en={ui.research.explore.en} zh={ui.research.explore.zh} /> <span class="arr" aria-hidden="true">&rarr;</span></span>
              </div>
              <div class="pillar-visual">
                {
                  v.img ? (
                    <img src={v.img} alt="" loading="lazy" style={`object-fit:${v.fit ?? "cover"}`} />
                  ) : v.trojan ? (
                    <LagrangeSurface bare />
                  ) : v.anim ? (
                    <PillarFigure kind={v.anim} />
                  ) : null
                }
                <span class="visual-fade" aria-hidden="true" />
              </div>
            </a>
          );
        })
      }
    </div>
  </main>
</BaseLayout>

<style>
  .pillars {
    display: flex;
    flex-direction: column;
    gap: clamp(1.4rem, 3vw, 2.1rem);
  }

  .pillar {
    --card-bg: #0e1622;
    position: relative;
    display: grid;
    grid-template-columns: 44% 56%;
    height: clamp(240px, 26vw, 320px);
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: #fff;
    border: 1px solid var(--line);
    background: linear-gradient(155deg, #14202f, var(--card-bg));
    box-shadow: 0 1px 0 var(--line);
    transition: transform 0.3s cubic-bezier(0.2, 0.7, 0.2, 1), box-shadow 0.3s, border-color 0.3s;
  }
  .pillar:hover,
  .pillar:focus-visible {
    transform: translateY(-5px);
    box-shadow: 0 22px 46px rgba(0, 0, 0, 0.5);
    border-color: rgba(255, 255, 255, 0.18);
    outline: none;
  }

  .pillar-body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(1.5rem, 3.4vw, 2.8rem);
    z-index: 1;
  }
  .pillar h2 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(1.45rem, 2.7vw, 2.1rem);
    line-height: 1.08;
    letter-spacing: -0.01em;
    margin: 0;
    text-wrap: balance;
  }
  .pillar-body p {
    font-size: clamp(0.95rem, 1.4vw, 1.06rem);
    line-height: 1.5;
    margin: 0.65rem 0 0;
    max-width: 42ch;
    color: rgba(226, 236, 252, 0.82);
  }
  .pillar-go {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.1rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: #fff;
  }
  .pillar-go .arr { transition: transform 0.25s; }
  .pillar:hover .pillar-go .arr,
  .pillar:focus-visible .pillar-go .arr { transform: translateX(5px); }

  .pillar-visual {
    position: relative;
    overflow: hidden;
    background: #0a1119;
  }
  .pillar-visual img,
  .pillar-visual :global(canvas) {
    width: 100%;
    height: 100%;
    display: block;
    object-position: center;
    transition: transform 0.6s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .pillar:hover .pillar-visual img,
  .pillar:hover .pillar-visual :global(canvas),
  .pillar:focus-visible .pillar-visual img,
  .pillar:focus-visible .pillar-visual :global(canvas) { transform: scale(1.05); }
  /* soft blend of the visual's left edge into the text column */
  .visual-fade {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(to right, var(--card-bg) 0%, rgba(14, 22, 34, 0.35) 12%, transparent 34%);
  }

  @media (max-width: 720px) {
    .pillar {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
      height: auto;
    }
    .pillar-visual { order: -1; aspect-ratio: 16 / 9; }
    .visual-fade { background: linear-gradient(to top, var(--card-bg) 0%, rgba(14, 22, 34, 0.25) 22%, transparent 45%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .pillar, .pillar-visual img, .pillar-visual :global(canvas), .pillar-go .arr { transition: none; }
  }
</style>
