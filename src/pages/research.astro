---
// src/pages/research.astro — pillar landing
import BaseLayout from "../layouts/BaseLayout.astro";
import { research } from "../data/research";

const BASE = import.meta.env.BASE_URL.replace(/\/+$/, "");
const link = (slug: string) => `${BASE}/research/${slug}`;
---

<BaseLayout title="Research — Research Group" description="Our research pillars.">
  <main class="wrap">
    <header class="masthead">
      <div class="eyebrow">What we do</div>
      <h1>Research</h1>
      <p>Our work is organised around a few core pillars. Explore each for details and related publications.</p>
    </header>

    <div class="pillars">
      {
        research.map((pillar, i) => (
          <a class="pillar" href={link(pillar.slug)}>
            <div class="pillar-media">
              <span class="pillar-num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
              <img
                src={BASE + pillar.image}
                alt={pillar.alt ?? pillar.title}
                loading="lazy"
                onerror="this.style.display='none'"
              />
              <div class="pillar-scrim" />
              <div class="pillar-text">
                <h2>{pillar.title}</h2>
                <p>{pillar.tagline}</p>
                <span class="pillar-go">Explore &rarr;</span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </main>
</BaseLayout>

<style>
  .pillars {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: clamp(1.25rem, 3vw, 2rem);
  }

  .pillar {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 1px 0 var(--line);
    transition: transform 0.25s cubic-bezier(0.2, 0.7, 0.2, 1), box-shadow 0.25s;
  }
  .pillar:hover,
  .pillar:focus-visible {
    transform: translateY(-4px);
    box-shadow: 0 14px 32px rgba(25, 28, 34, 0.12);
    outline: none;
  }

  .pillar-media {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--accent);
    overflow: hidden;
  }
  .pillar-num {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: grid;
    place-items: center;
    font-family: var(--serif);
    font-size: clamp(3rem, 8vw, 5rem);
    color: #fff;
    opacity: 0.22;
  }
  .pillar-media img {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .pillar:hover .pillar-media img { transform: scale(1.05); }

  /* dark gradient so the title stays legible over any photo */
  .pillar-scrim {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(to top, rgba(10, 12, 15, 0.72) 0%, rgba(10, 12, 15, 0.15) 45%, transparent 70%);
  }
  .pillar-text {
    position: absolute;
    z-index: 3;
    left: 0;
    right: 0;
    bottom: 0;
    padding: clamp(1rem, 3vw, 1.5rem);
    color: #fff;
  }
  .pillar-text h2 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
  }
  .pillar-text p {
    font-size: 0.95rem;
    margin-top: 0.35rem;
    opacity: 0.9;
    max-width: 40ch;
  }
  .pillar-go {
    display: inline-block;
    margin-top: 0.7rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: #fff;
  }
</style>
