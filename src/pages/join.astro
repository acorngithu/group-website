---
// src/pages/join.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import { join } from "../data/join";
import { ui } from "../data/i18n";
import Bi from "../components/Bi.astro";

const BASE = import.meta.env.BASE_URL.replace(/\/+$/, "");
const open = join.positions.filter((p) => p.open);
---

<BaseLayout title="Join us — Wu Lab" description="Open positions and how to join the group.">
  <main class="wrap">
    <header class="masthead">
      <div class="eyebrow"><Bi en={ui.join.eyebrow.en} zh={ui.join.eyebrow.zh} /></div>
      <h1><Bi en={ui.join.title.en} zh={ui.join.title.zh} /></h1>
      <p><Bi en={join.intro} zh={join.introZh} /></p>
    </header>

    <section class="positions" aria-label="Open positions">
      <h2 class="section-heading">
        <Bi en={ui.join.openPositions.en} zh={ui.join.openPositions.zh} />
      </h2>
      {
        open.length > 0 ? (
          <div class="pos-list">
            {open.map((p) => {
              // Positions with a detail page render as a clickable link card;
              // the rest stay as a plain (non-clickable) article.
              const Tag = p.slug ? "a" : "article";
              return (
                <Tag class={p.slug ? "pos pos-link" : "pos"} href={p.slug ? `${BASE}/join/${p.slug}` : undefined}>
                  <div class="pos-head">
                    <h3><Bi en={p.title} zh={p.titleZh} /></h3>
                    {p.detail && <span class="pos-detail"><Bi en={p.detail} zh={p.detailZh ?? p.detail} /></span>}
                  </div>
                  <p><Bi en={p.description} zh={p.descriptionZh} /></p>
                  {p.slug && (
                    <span class="pos-more"><Bi en={ui.join.learnMore.en} zh={ui.join.learnMore.zh} /></span>
                  )}
                </Tag>
              );
            })}
          </div>
        ) : (
          <p class="empty"><Bi en={ui.join.noPositions.en} zh={ui.join.noPositions.zh} /></p>
        )
      }
    </section>

    <section class="apply" aria-label="How to apply">
      <h2 class="section-heading"><Bi en={ui.join.howToApply.en} zh={ui.join.howToApply.zh} /></h2>
      <div class="prose">
        {join.howToApply.map((para, i) => <p><Bi en={para} zh={join.howToApplyZh[i]} /></p>)}
      </div>
      <a class="contact" href={`mailto:${join.contactEmail}`}>{join.contactEmail}</a>
    </section>
  </main>
</BaseLayout>

<style>
  .positions { margin-bottom: clamp(2.5rem, 5vw, 3.5rem); }
  .pos-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: clamp(1rem, 2.5vw, 1.5rem);
  }
  .pos {
    padding: 1.4rem;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.03);
  }
  /* Positions with a detail page are a whole clickable card */
  a.pos-link {
    display: block;
    color: inherit;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s cubic-bezier(0.2, 0.7, 0.2, 1), border-color 0.2s, background 0.2s, box-shadow 0.2s;
  }
  a.pos-link:hover,
  a.pos-link:focus-visible {
    transform: translateY(-3px);
    border-color: var(--accent);
    background: var(--accent-soft);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.28);
    outline: none;
  }
  .pos-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
  }
  .pos-head h3 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.25rem;
  }
  .pos-detail {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
  }
  .pos p { color: var(--muted); font-size: 0.98rem; }
  /* Visual call-to-action inside the clickable card (not a link itself) */
  .pos-more {
    display: inline-block;
    margin-top: 0.9rem;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--accent);
  }
  a.pos-link:hover .pos-more { text-decoration: underline; text-underline-offset: 3px; }

  .prose { max-width: 68ch; }
  .prose p { color: var(--ink); font-size: 1.05rem; line-height: 1.7; }
  .prose p + p { margin-top: 0.9rem; }

  .contact {
    display: inline-block;
    margin-top: 1.4rem;
    padding: 0.6rem 1.1rem;
    border-radius: 8px;
    background: var(--accent);
    color: #fff;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: opacity 0.18s;
  }
  .contact:hover,
  .contact:focus-visible { opacity: 0.88; outline: none; }

  .empty { color: var(--muted); }
</style>
