---
// src/pages/index.astro — Home (dark "physical neural" theme, neural-field background)
// NOTE: the previous academic Home is preserved at design-backups/index.academic.astro.
// To revert, copy that file back over this one.
import NeuralField from "../components/NeuralField.astro";
import { site } from "../data/site";
import { news, formatDate, formatDateZh } from "../data/news";
import { ui, langBootScript } from "../data/i18n";
import Bi from "../components/Bi.astro";
import LangToggle from "../components/LangToggle.astro";

const BASE = import.meta.env.BASE_URL.replace(/\/+$/, "");
const href = (p: string) => (p === "/" ? BASE || "/" : BASE + p);

const latestNews = [...news].sort((a, b) => (a.date < b.date ? 1 : -1)).slice(0, 4);
const nav = [
  { h: "/research", l: ui.nav.research },
  { h: "/people", l: ui.nav.people },
  { h: "/publications", l: ui.nav.publications },
  { h: "/gallery", l: ui.nav.gallery },
  { h: "/join", l: ui.nav.join },
];
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={site.tagline} />
    <link rel="icon" href={`${BASE}/favicon.svg`} />
    <script is:inline set:html={langBootScript} />
    <style is:global>
      /* Home is standalone (no BaseLayout), so it needs its own copy of the
         language-visibility rule that global.css provides to every other page. */
      html:not([data-lang="zh"]) .lang-zh { display: none; }
      html[data-lang="zh"] .lang-en { display: none; }
    </style>
    <title>{site.name}</title>
  </head>
  <body>
    <NeuralField />

    <div class="home">
      <header class="hd">
        <div class="wrap">
          <a class="brand" href={href("/")}><Bi en={site.name} zh={site.nameZh} /></a>
          <div class="nav-right">
            <nav>
              {nav.map((i) => <a href={href(i.h)}><Bi en={i.l.en} zh={i.l.zh} /></a>)}
            </nav>
            <LangToggle />
          </div>
        </div>
      </header>

      <section class="hero">
        <div class="wrap">
          <div class="hero-inner">
            <div class="eyebrow"><Bi en={site.institution} zh={site.institutionZh} /></div>
            <h1><Bi en={site.name} zh={site.nameZh} /></h1>
            {site.intro.map((para) => <p class="lead"><Bi en={para.en} zh={para.zh} /></p>)}
            <div class="cta-row">
              <a class="btn primary" href={href("/research")}><Bi en={ui.home.exploreResearch.en} zh={ui.home.exploreResearch.zh} /></a>
              <a class="btn ghost" href={href("/join")}><Bi en={ui.home.joinUs.en} zh={ui.home.joinUs.zh} /></a>
            </div>
          </div>
        </div>
      </section>

      <div class="below">
        <div class="wrap sections">
          {
            latestNews.length > 0 && (
              <section class="news" aria-label="News">
                <div class="sec-head">
                  <h2 class="label"><Bi en={ui.home.news.en} zh={ui.home.news.zh} /></h2>
                </div>
                <ul class="news-list">
                  {latestNews.map((item) => {
                    // slug (own page) wins over url (link out); both are internal
                    // except a full https:// url, which opens in a new tab.
                    const isExternal = !item.slug && item.url && /^https?:\/\//.test(item.url);
                    const newsHref = item.slug
                      ? href(`/news/${item.slug}`)
                      : item.url
                        ? (isExternal ? item.url : href(item.url))
                        : undefined;
                    return (
                      <li>
                        <time datetime={item.date}><Bi en={formatDate(item.date)} zh={formatDateZh(item.date)} /></time>
                        {newsHref ? (
                          <a href={newsHref} target={isExternal ? "_blank" : undefined} rel={isExternal ? "noopener" : undefined}>
                            <Bi en={item.title} zh={item.titleZh} />
                          </a>
                        ) : (
                          <span><Bi en={item.title} zh={item.titleZh} /></span>
                        )}
                      </li>
                    );
                  })}
                </ul>
              </section>
            )
          }

          <section class="join-cta">
            <div>
              <h2><Bi en={ui.home.joinTitle.en} zh={ui.home.joinTitle.zh} /></h2>
              <p><Bi en={ui.home.joinBlurb.en} zh={ui.home.joinBlurb.zh} /></p>
            </div>
            <a class="btn primary" href={href("/join")}><Bi en={ui.home.seePositions.en} zh={ui.home.seePositions.zh} /></a>
          </section>
        </div>

        <footer class="ft">
          <div class="wrap">
            <span>© {year} <Bi en={site.name} zh={site.nameZh} /></span>
            <span><Bi en={site.institution} zh={site.institutionZh} /></span>
          </div>
        </footer>
      </div>
    </div>
  </body>
</html>

<style>
  @font-face {
    font-family: "SpaceGrotesk";
    src: url("/fonts/SpaceGrotesk.woff2") format("woff2");
    font-weight: 400 700;
    font-display: swap;
  }

  :root {
    --hbg: #0a1119;
    --ink: #eaf1ff;
    --muted: #9fb0c6;
    --accent: #3d74ff;
    --accent2: #7fa6ff;
    --warm: #f5934a;
    --line: rgba(255, 255, 255, 0.1);
    --card: rgba(18, 28, 42, 0.55);
    --display: "SpaceGrotesk", system-ui, sans-serif;
    --sans: "Segoe UI", system-ui, -apple-system, Roboto, Arial, sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: var(--hbg); color: var(--ink); font-family: var(--sans); line-height: 1.6; -webkit-font-smoothing: antialiased; }
  .wrap { max-width: 1120px; margin: 0 auto; padding: 0 clamp(1.25rem, 4vw, 2.5rem); }

  .home { position: relative; z-index: 2; }

  header.hd { position: absolute; top: 0; left: 0; right: 0; z-index: 3; }
  header.hd .wrap { display: flex; align-items: center; justify-content: space-between; gap: 1rem; min-height: 74px; flex-wrap: wrap; }
  .brand { font-family: var(--display); font-weight: 700; font-size: 1.05rem; letter-spacing: 0.01em; text-decoration: none; color: #fff; }
  .nav-right { display: flex; align-items: center; flex-wrap: wrap; gap: 0.55rem 1.2rem; }
  .hd nav { display: flex; flex-wrap: wrap; gap: 1.4rem; font-size: 0.9rem; }
  .hd nav a { color: var(--muted); text-decoration: none; transition: color 0.18s; }
  .hd nav a:hover, .hd nav a:focus-visible { color: #fff; outline: none; }

  /* hero: full-width container so its left edge lines up with the sections below */
  .hero { min-height: 100vh; display: flex; align-items: center; }
  .hero > .wrap { width: 100%; }
  .hero-inner { max-width: 52ch; padding: 8rem 0 4rem; }
  .eyebrow { font-family: var(--display); font-size: 0.74rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent2); display: flex; align-items: center; gap: 0.7rem; margin-bottom: 1.1rem; }
  .eyebrow::before { content: ""; width: 30px; height: 2px; background: var(--accent2); }
  .hero h1 { font-family: var(--display); font-size: clamp(2.6rem, 6.5vw, 4.6rem); font-weight: 700; line-height: 1.02; letter-spacing: -0.02em; text-wrap: balance; background: linear-gradient(100deg, #ffffff 55%, #7fa6ff); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .lead { color: #c7d3e4; font-size: clamp(1.05rem, 1.6vw, 1.22rem); margin-top: 1.1rem; max-width: 52ch; }
  .lead:first-of-type { margin-top: 1.2rem; }

  .cta-row { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 1.9rem; }
  .btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.8rem 1.35rem; border-radius: 9px; font-weight: 600; font-family: var(--display); font-size: 0.95rem; text-decoration: none; border: 1px solid transparent; transition: transform 0.15s, box-shadow 0.2s, background 0.2s; }
  .btn.primary { background: var(--accent); color: #fff; box-shadow: 0 8px 24px rgba(61, 116, 255, 0.4); }
  .btn.primary:hover { transform: translateY(-2px); }
  .btn.ghost { border-color: rgba(255, 255, 255, 0.28); color: #fff; }
  .btn.ghost:hover { border-color: #fff; background: rgba(255, 255, 255, 0.06); }

  /* everything below the hero sits on an opaque panel that covers the field */
  .below { position: relative; background: var(--hbg); border-top: 1px solid var(--line); }
  .sections { padding: clamp(3rem, 7vw, 5rem) clamp(1.25rem, 4vw, 2.5rem); display: flex; flex-direction: column; gap: clamp(2.75rem, 6vw, 4.5rem); }

  .sec-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 1.3rem; }
  .label { font-family: var(--display); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); }

  .news-list { list-style: none; display: flex; flex-direction: column; }
  .news-list li { display: grid; grid-template-columns: 8rem 1fr; gap: 0.75rem; padding: 0.7rem 0; border-bottom: 1px solid var(--line); align-items: baseline; }
  .news-list li:last-child { border-bottom: none; }
  .news-list time { color: var(--accent2); font-size: 0.85rem; font-variant-numeric: tabular-nums; }
  .news-list a, .news-list span { color: var(--ink); text-decoration: none; }
  .news-list a { border-bottom: 1px solid var(--line); transition: color 0.18s, border-color 0.18s; }
  .news-list a:hover { color: var(--accent2); border-color: var(--accent2); }

  .join-cta { padding: clamp(1.5rem, 4vw, 2.25rem); border-radius: 14px; background: rgba(61, 116, 255, 0.12); border: 1px solid rgba(61, 116, 255, 0.4); display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem 1.5rem; }
  .join-cta h2 { font-family: var(--display); font-weight: 600; font-size: 1.5rem; color: #fff; }
  .join-cta p { color: #c7d3e4; margin-top: 0.2rem; }

  .ft { border-top: 1px solid var(--line); padding: 2rem 0; }
  .ft .wrap { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 0.5rem; color: var(--muted); font-size: 0.85rem; }

  @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }
</style>
