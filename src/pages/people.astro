---
// src/pages/people.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import { people, roleSections } from "../data/people";
import PersonCard from "../components/PersonCard.astro";
import { ui } from "../data/i18n";
import Bi from "../components/Bi.astro";

// Group members by role section; hide empty sections.
const grouped = roleSections
  .map((s) => ({ ...s, members: people.filter((p) => p.role === s.role) }))
  .filter((s) => s.members.length > 0);

// Anyone without a known role still shows, under a trailing "Others" section.
const known = new Set(roleSections.map((s) => s.role));
const others = people.filter((p) => !p.role || !known.has(p.role));
---

<BaseLayout title="People — Wu Lab" description="The people who make up the group." theme="dark">
  <main class="wrap">
    <header class="masthead">
      <div class="eyebrow"><Bi en={ui.people.eyebrow.en} zh={ui.people.eyebrow.zh} /></div>
      <h1><Bi en={ui.people.title.en} zh={ui.people.title.zh} /></h1>
    </header>

    {
      grouped.map((sec) => (
        <section class="role-section" aria-label={sec.label}>
          <h2 class="section-heading"><Bi en={sec.label} zh={sec.labelZh} /></h2>
          <div class="people">
            {sec.members.map((person) => (
              <PersonCard person={person} />
            ))}
          </div>
        </section>
      ))
    }

    {
      others.length > 0 && (
        <section class="role-section" aria-label="Others">
          <h2 class="section-heading"><Bi en={ui.people.others.en} zh={ui.people.others.zh} /></h2>
          <div class="people">
            {others.map((person) => (
              <PersonCard person={person} />
            ))}
          </div>
        </section>
      )
    }
  </main>
</BaseLayout>

<style>
  .role-section { margin-bottom: clamp(2.5rem, 5vw, 3.5rem); }
  .people {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
    gap: clamp(1.5rem, 3vw, 2.5rem) clamp(1.25rem, 3vw, 2rem);
  }
</style>
