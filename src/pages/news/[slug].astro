---
// src/pages/news/[slug].astro — one news item's own page.
// A page is generated for every item in src/data/news.ts that has a `slug`.
// Items without a slug never reach here (they stay on the home strip only).
import BaseLayout from "../../layouts/BaseLayout.astro";
import { news, formatDate, formatDateZh } from "../../data/news";
import { ui } from "../../data/i18n";
import Bi from "../../components/Bi.astro";

export function getStaticPaths() {
  return news
    .filter((item) => item.slug)
    .map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/+$/, "");
const body = item.body ?? [];
const bodyZh = item.bodyZh ?? [];

// Body may contain inline HTML links. Write internal links as
// <a href="{base}/join">…</a>; {base} is swapped for the real site base here so
// the link works under a project Pages base or at a custom-domain root alike.
const withBase = (s: string) => s.replaceAll("{base}", BASE || "");
---

<BaseLayout title={`${item.title} — News`} description={item.title}>
  <main class="wrap">
    <a class="back" href={BASE || "/"}><Bi en={ui.news.back.en} zh={ui.news.back.zh} /></a>

    <header class="masthead">
      <div class="eyebrow"><Bi en={ui.news.eyebrow.en} zh={ui.news.eyebrow.zh} /></div>
      <h1><Bi en={item.title} zh={item.titleZh} /></h1>
      <p class="news-date">
        <time datetime={item.date}><Bi en={formatDate(item.date)} zh={formatDateZh(item.date)} /></time>
      </p>
    </header>

    {
      item.image && (
        <figure
          class:list={[
            "news-figure",
            item.imageLang === "zh" && "lang-zh",
            item.imageLang === "en" && "lang-en",
          ]}
        >
          <img
            src={/^https?:\/\//.test(item.image) ? item.image : BASE + item.image}
            alt={item.imageAlt ?? item.title}
            loading="lazy"
            onerror="this.closest('figure')?.remove()"
          />
          {item.caption && (
            <figcaption><Bi en={item.caption} zh={item.captionZh ?? item.caption} /></figcaption>
          )}
        </figure>
      )
    }

    <div class="prose">
      {body.map((para, i) => <p><Bi en={withBase(para)} zh={withBase(bodyZh[i] ?? para)} /></p>)}
    </div>
  </main>
</BaseLayout>

<style>
  .back {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.18s;
  }
  .back:hover,
  .back:focus-visible { color: var(--ink); outline: none; }

  .news-date { color: var(--accent); font-variant-numeric: tabular-nums; margin-top: 0.6rem; }

  /* Flyer / figure. Portrait flyers stay a sensible size via max-width. */
  .news-figure { margin: 1.75rem 0 0; }
  .news-figure img {
    display: block;
    width: 100%;
    max-width: 560px;
    height: auto;
    border-radius: 10px;
    border: 1px solid var(--line);
  }
  .news-figure figcaption {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
    margin-top: 0.6rem;
    max-width: 560px;
  }

  .prose { margin-top: 1.75rem; max-width: 68ch; }
  /* Inline images inside body text stay responsive too */
  .prose :global(img) { max-width: 100%; height: auto; border-radius: 8px; margin: 1rem 0; }
  .prose p { color: var(--ink); font-size: 1.08rem; line-height: 1.7; }
  .prose p + p { margin-top: 1.1rem; }
  .prose :global(a) {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent-soft);
    transition: border-color 0.18s;
  }
  .prose :global(a:hover),
  .prose :global(a:focus-visible) { border-color: var(--accent); outline: none; }
</style>
