---
// src/pages/research/[slug].astro — one research pillar's subpage
import BaseLayout from "../../layouts/BaseLayout.astro";
import Figure from "../../components/Figure.astro";
import PillarFigure from "../../components/PillarFigure.astro";
import LagrangeSurface from "../../components/LagrangeSurface.astro";
import BICFilm from "../../components/BICFilm.astro";
import { research } from "../../data/research";
import { ui } from "../../data/i18n";
import Bi from "../../components/Bi.astro";

export function getStaticPaths() {
  return research.map((pillar) => ({
    params: { slug: pillar.slug },
    props: { pillar },
  }));
}

const { pillar } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/+$/, "");
---

<BaseLayout title={`${pillar.title} — Research`} description={pillar.tagline}>
  <main class="wrap">
    <a class="back" href={`${BASE}/research`}><Bi en="&larr; All research" zh="&larr; 全部研究" /></a>

    <header class="pillar-head">
      <div class="eyebrow"><Bi en={ui.pillar.eyebrow.en} zh={ui.pillar.eyebrow.zh} /></div>
      <h1><Bi en={pillar.title} zh={pillar.titleZh} /></h1>
      {/* English name as a subtitle — shows only in Chinese mode (lang-zh) */}
      <div class="pillar-en-sub lang-zh">{pillar.title}</div>
      <p class="lead"><Bi en={pillar.tagline} zh={pillar.taglineZh} /></p>
    </header>

    {
      pillar.slug === "complex-light-dynamics" ? (
        <div class="cld-panels">
          <figure class="cld-panel">
            <figcaption class="panel-head">
              <span class="panel-title"><Bi en={ui.pillar.trojanTitle.en} zh={ui.pillar.trojanTitle.zh} /></span>
              <span class="panel-sub"><Bi en={ui.pillar.trojanSub.en} zh={ui.pillar.trojanSub.zh} /></span>
            </figcaption>
            <LagrangeSurface aspect={16 / 9} />
          </figure>
          <figure class="cld-panel">
            <figcaption class="panel-head">
              <span class="panel-title"><Bi en={ui.pillar.bicTitle.en} zh={ui.pillar.bicTitle.zh} /></span>
              <span class="panel-sub"><Bi en={ui.pillar.bicSub.en} zh={ui.pillar.bicSub.zh} /></span>
            </figcaption>
            <div class="cld-bic"><BICFilm controls={false} externalCaption hideHeader /></div>
          </figure>
        </div>
      ) : (
        <div class="hero-media">
          {
            pillar.animation ? (
              <PillarFigure kind={pillar.animation} />
            ) : (
              <Fragment>
                <span class="hero-fallback" aria-hidden="true">{pillar.title}</span>
                <img
                  src={BASE + pillar.image}
                  alt={pillar.alt ?? pillar.title}
                  onerror="this.style.display='none'"
                />
              </Fragment>
            )
          }
        </div>
      )
    }

    <div class="prose">
      {pillar.description.map((para, i) => <p><Bi en={para} zh={pillar.descriptionZh[i]} /></p>)}
    </div>

    {
      pillar.figures && pillar.figures.length > 0 && (
        <section class="figures" aria-label="Figures">
          <h2 class="section-heading"><Bi en={ui.pillar.figures.en} zh={ui.pillar.figures.zh} /></h2>
          <div class="fig-grid">
            {pillar.figures.map((f) => <Figure src={f.src} caption={f.caption} alt={f.alt} />)}
          </div>
        </section>
      )
    }

    {
      pillar.references && pillar.references.length > 0 && (
        <section class="refs" aria-label="Further reading">
          <h2 class="section-heading"><Bi en={ui.pillar.furtherReading.en} zh={ui.pillar.furtherReading.zh} /></h2>
          <ol class="ref-list">
            {pillar.references.map((r) => (
              <li>
                <div class="r-body">
                  <div class="r-title">
                    {r.url ? <a href={r.url} target="_blank" rel="noopener">{r.title}</a> : r.title}
                  </div>
                  <div class="r-meta">{r.authors} · <span class="r-venue">{r.venue}</span>, {r.year}</div>
                </div>
              </li>
            ))}
          </ol>
        </section>
      )
    }
  </main>
</BaseLayout>

<style>
  .back {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.18s;
  }
  .back:hover,
  .back:focus-visible { color: var(--ink); outline: none; }

  .pillar-head { margin-bottom: 1.75rem; }
  .pillar-head h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2.1rem, 5vw, 3.1rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0.3rem 0 0.7rem;
  }
  /* English name shown under the Chinese title (Chinese mode only) */
  .pillar-en-sub {
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    font-weight: 400;
    letter-spacing: 0.01em;
    color: var(--muted);
    margin: -0.35rem 0 0.8rem;
  }

  .hero-media {
    position: relative;
    aspect-ratio: 21 / 9;
    border-radius: 12px;
    overflow: hidden;
    background: var(--accent-soft);
    margin-bottom: clamp(1.75rem, 4vw, 2.75rem);
  }
  .cld-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(0.5rem, 1.4vw, 0.9rem);
    align-items: start;
    margin-bottom: clamp(1.75rem, 4vw, 2.75rem);
  }
  .cld-panel { margin: 0; display: flex; flex-direction: column; }

  /* Panel title + subtitle, sitting at the top of each panel */
  .panel-head { text-align: center; margin: 0 0 0.85rem; }
  .panel-title {
    display: block;
    font-family: var(--serif);
    font-weight: 400;
    font-size: 1.3rem;
    line-height: 1.2;
    color: var(--ink);
  }
  .panel-sub {
    display: block;
    margin-top: 0.15rem;
    font-size: 0.9rem;
    color: var(--muted);
  }

  .cld-bic { width: 100%; }
  @media (max-width: 640px) { .cld-panels { grid-template-columns: 1fr; } }
  .hero-fallback {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: 1rem;
    text-align: center;
    font-family: var(--serif);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    color: var(--accent);
    opacity: 0.5;
  }
  .hero-media img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .prose {
    max-width: 68ch;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .prose p {
    color: var(--ink);
    font-size: 1.08rem;
    line-height: 1.7;
  }
  .prose p + p { margin-top: 1.1rem; }

  .figures { margin-bottom: clamp(2.5rem, 5vw, 3.5rem); }
  .fig-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: clamp(1rem, 2.5vw, 1.4rem); }

  .refs { margin-bottom: clamp(2.5rem, 5vw, 3.5rem); }
  .ref-list { counter-reset: ref; list-style: none; display: flex; flex-direction: column; gap: 1rem; max-width: 82ch; }
  .ref-list li { display: grid; grid-template-columns: 1.9rem 1fr; gap: 0.5rem; }
  .ref-list li::before {
    counter-increment: ref;
    content: counter(ref) ".";
    color: var(--accent);
    font-variant-numeric: tabular-nums;
    font-size: 0.9rem;
    padding-top: 0.15rem;
  }
  .r-title { font-size: 1rem; font-weight: 500; line-height: 1.4; color: var(--ink); }
  .r-title a { color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--line); transition: color 0.18s, border-color 0.18s; }
  .r-title a:hover, .r-title a:focus-visible { color: var(--accent); border-color: var(--accent); outline: none; }
  .r-meta { color: var(--muted); font-size: 0.9rem; margin-top: 0.15rem; }
  .r-venue { font-style: italic; }
</style>
