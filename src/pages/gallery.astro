---
// src/pages/gallery.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import { gallery } from "../data/gallery";
import { ui } from "../data/i18n";
import Bi from "../components/Bi.astro";

const BASE = import.meta.env.BASE_URL.replace(/\/+$/, "");
---

<BaseLayout title="Gallery — Research Group" description="Photos from the group.">
  <main class="wrap">
    <header class="masthead">
      <div class="eyebrow"><Bi en={ui.gallery.eyebrow.en} zh={ui.gallery.eyebrow.zh} /></div>
      <h1><Bi en={ui.gallery.title.en} zh={ui.gallery.title.zh} /></h1>
      <p><Bi en={ui.gallery.subtitle.en} zh={ui.gallery.subtitle.zh} /></p>
    </header>

    {
      gallery.length > 0 ? (
        <div class="grid">
          {gallery.map((item, i) => (
            <figure class="tile">
              <div class="tile-media">
                <span class="tile-fallback" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
                <img
                  src={BASE + item.src}
                  alt={item.alt ?? item.caption ?? "Group photo"}
                  loading="lazy"
                  onerror="this.style.display='none'"
                />
              </div>
              {item.caption && <figcaption><Bi en={item.caption} zh={item.captionZh ?? item.caption} /></figcaption>}
            </figure>
          ))}
        </div>
      ) : (
        <p class="empty"><Bi en="No photos yet — add some in <code>/public/gallery/</code> and list them in <code>src/data/gallery.ts</code>." zh="暂无照片 —— 请将图片放入 <code>/public/gallery/</code>，并在 <code>src/data/gallery.ts</code> 中登记。" /></p>
      )
    }
  </main>
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: clamp(1rem, 2.5vw, 1.5rem);
  }
  .tile { display: flex; flex-direction: column; }
  .tile-media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 8px;
    background: var(--accent-soft);
    box-shadow: 0 1px 0 var(--line);
  }
  .tile-fallback {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-family: var(--serif);
    font-size: 1.6rem;
    color: var(--accent);
    opacity: 0.4;
  }
  .tile-media img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .tile:hover .tile-media img { transform: scale(1.04); }

  figcaption {
    color: var(--muted);
    font-size: 0.85rem;
    margin-top: 0.55rem;
    line-height: 1.4;
  }
  .empty { color: var(--muted); }
  .empty code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.85em; }
</style>
