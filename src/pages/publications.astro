---
// src/pages/publications.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import PubList from "../components/PubList.astro";
import { publications, pubSections } from "../data/publications";
import { site } from "../data/site";
import { ui } from "../data/i18n";
import Bi from "../components/Bi.astro";

// Featured flagship-venue papers, newest first.
const selected = publications
  .filter((p) => p.selected)
  .sort((a, b) => b.year - a.year);

// The remaining entries, grouped by section type; newest year first; drop empties.
const grouped = pubSections
  .map((s) => ({
    ...s,
    items: publications
      .filter((p) => p.type === s.type && !p.selected)
      .sort((a, b) => b.year - a.year),
  }))
  .filter((s) => s.items.length > 0);
---

<BaseLayout title="Publications — Wu Lab" description="Selected flagship-venue publications from the group.">
  <main class="wrap">
    <header class="masthead">
      <div class="eyebrow"><Bi en={ui.publications.eyebrow.en} zh={ui.publications.eyebrow.zh} /></div>
      <h1><Bi en={ui.publications.title.en} zh={ui.publications.title.zh} /></h1>
      <p class="scholar-note"><Bi en={ui.publications.scholarPre.en} zh={ui.publications.scholarPre.zh} /><a href={site.scholar} target="_blank" rel="noopener">Google Scholar</a><Bi en={ui.publications.scholarPost.en} zh={ui.publications.scholarPost.zh} /></p>
    </header>

    {
      selected.length > 0 && (
        <section class="pub-section" aria-label="Selected Publications">
          <h2 class="section-heading"><Bi en={ui.publications.selected.en} zh={ui.publications.selected.zh} /></h2>
          <PubList items={selected} />
        </section>
      )
    }

    {
      grouped.map((sec) => (
        <section class="pub-section" aria-label={sec.label}>
          <h2 class="section-heading"><Bi en={sec.label} zh={sec.labelZh} /></h2>
          <PubList items={sec.items} />
        </section>
      ))
    }
  </main>
</BaseLayout>

<style>
  /* Citation list styling lives in PubList.astro (shared with pillar pages). */
  .pub-section { margin-bottom: clamp(2.5rem, 5vw, 3.5rem); }

  .scholar-note { color: var(--muted); }
  .scholar-note a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent-soft);
    transition: border-color 0.18s;
  }
  .scholar-note a:hover,
  .scholar-note a:focus-visible { border-color: var(--accent); outline: none; }
</style>
