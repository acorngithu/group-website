---
// src/components/PubList.astro
// Renders a list of publications, each with an optional graphical-abstract
// thumbnail on the left (matted, so white-background figures look clean on the
// dark theme). Shared by the Publications page and each pillar's related list.
import type { Publication } from "../data/publications";

const { items } = Astro.props as { items: Publication[] };
const BASE = import.meta.env.BASE_URL.replace(/\/+$/, "");
const asset = (p: string) => (/^https?:\/\//.test(p) ? p : BASE + p);
---

<ol class="pub-list">
  {
    items.map((p) => (
      <li class="pub">
        <div class:list={["pub-thumb", { empty: !p.thumbnail }]}>
          {p.thumbnail ? (
            <div class="mat">
              <img src={asset(p.thumbnail)} alt={`Figure for “${p.title}”`} loading="lazy" onerror="this.closest('.pub-thumb')?.classList.add('empty')" />
            </div>
          ) : (
            <span class="ph" aria-hidden="true">Figure</span>
          )}
        </div>

        <div class="pub-body">
          <div class="pub-title">
            {p.url ? (
              <a href={p.url} target="_blank" rel="noopener">{p.title}</a>
            ) : (
              p.title
            )}
          </div>
          <div class="pub-authors">{p.authors}</div>
          <div class="pub-meta">
            <span class="venue">{p.venue}</span>
            <span class="year">{p.year}</span>
            {p.note && <span class="badge">{p.note}</span>}
          </div>
        </div>
      </li>
    ))
  }
</ol>

<style>
  .pub-list { list-style: none; display: flex; flex-direction: column; }
  .pub {
    display: grid;
    grid-template-columns: clamp(110px, 13vw, 130px) 1fr;
    gap: clamp(1rem, 2.5vw, 1.5rem);
    padding: 1.3rem 0;
    border-bottom: 1px solid var(--line);
    align-items: start;
  }
  .pub:last-child { border-bottom: none; }

  /* thumbnail — figure sits flush on a clean white tile (white blends with the
     figures' own white backgrounds, so there's no visible frame on the dark page) */
  .pub-thumb {
    aspect-ratio: 4 / 3;
    border-radius: 10px;
    overflow: hidden;
  }
  .pub-thumb .mat { background: #fff; width: 100%; height: 100%; display: grid; place-items: center; }
  .pub-thumb img { width: 100%; height: 100%; object-fit: contain; display: block; }
  .pub-thumb.empty {
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, 0.03);
    border: 1px dashed var(--line);
  }
  .pub-thumb.empty .mat, .pub-thumb.empty img { display: none; }
  .pub-thumb .ph { color: var(--muted); opacity: 0.5; font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; }

  .pub-title { font-size: 1.05rem; font-weight: 600; line-height: 1.35; letter-spacing: -0.005em; }
  .pub-title a { color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--line); transition: border-color 0.18s, color 0.18s; }
  .pub-title a:hover, .pub-title a:focus-visible { color: var(--accent); border-color: var(--accent); outline: none; }

  .pub-authors { color: var(--muted); font-size: 0.92rem; margin-top: 0.25rem; }
  .pub-meta { font-size: 0.92rem; margin-top: 0.3rem; display: flex; flex-wrap: wrap; gap: 0.55rem; align-items: baseline; }
  .venue { font-style: italic; color: var(--ink); }
  .year { color: var(--accent); font-variant-numeric: tabular-nums; }
  .badge {
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.03em; text-transform: uppercase;
    color: var(--accent); background: var(--accent-soft);
    padding: 0.1rem 0.5rem; border-radius: 999px;
  }

  @media (max-width: 620px) {
    .pub { grid-template-columns: 1fr; gap: 0.85rem; }
    .pub-thumb { max-width: 200px; }
  }
</style>
