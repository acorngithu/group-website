---
// src/components/NeuralField.astro
// Full-screen animated "neural field" background (HTML canvas).
// China-safe: pure vanilla JS, no libraries, no external requests.
// Pauses when the tab is hidden and honors prefers-reduced-motion.
---

<canvas id="neural-bg" aria-hidden="true"></canvas>
<div class="neural-scrim" aria-hidden="true"></div>

<style>
  #neural-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    z-index: 0;
    background: #0a1119;
  }
  /* legibility scrim: darker at the left where the headline sits, + vignette */
  .neural-scrim {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgba(10,17,25,.92) 0%, rgba(10,17,25,.7) 34%, rgba(10,17,25,.32) 68%, rgba(10,17,25,.12) 100%),
      radial-gradient(120% 120% at 72% 26%, transparent 42%, rgba(6,11,18,.55) 100%);
  }
</style>

<script>
  const REDUCE = matchMedia("(prefers-reduced-motion: reduce)").matches;
  const DPR = Math.min(2, devicePixelRatio || 1);
  const TAU = Math.PI * 2;
  const cv = document.getElementById("neural-bg");
  if (cv) {
    const ctx = cv.getContext("2d");
    let w = 0, h = 0, nodes = [], signals = [];
    const mouse = { x: 0, y: 0, tx: 0, ty: 0 };

    function build() {
      const r = cv.getBoundingClientRect();
      w = Math.round(r.width); h = Math.round(r.height);
      cv.width = w * DPR; cv.height = h * DPR;
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      const N = Math.max(36, Math.min(120, Math.round((w * h) / 22000)));
      nodes = [];
      for (let i = 0; i < N; i++) {
        const z = Math.random();
        nodes.push({
          x: Math.random() * w, y: Math.random() * h, z,
          vx: (Math.random() - .5) * (6 + z * 14),
          vy: (Math.random() - .5) * (6 + z * 14),
          r: 0.6 + z * 2.4, b: 0.22 + z * 0.78,
          warm: Math.random() < 0.13,
        });
      }
      nodes.sort((a, b) => a.z - b.z);
    }
    build();
    new ResizeObserver(build).observe(cv);
    addEventListener("mousemove", (e) => { mouse.tx = (e.clientX / innerWidth - .5); mouse.ty = (e.clientY / innerHeight - .5); });

    function glow(x, y, r, color) {
      const g = ctx.createRadialGradient(x, y, 0, x, y, r);
      g.addColorStop(0, color); g.addColorStop(1, "rgba(0,0,0,0)");
      ctx.fillStyle = g; ctx.beginPath(); ctx.arc(x, y, r, 0, TAU); ctx.fill();
    }

    const M = 60;
    let acc = 0;
    function frame(dt) {
      mouse.x += (mouse.tx - mouse.x) * 0.05; mouse.y += (mouse.ty - mouse.y) * 0.05;
      ctx.globalCompositeOperation = "source-over";
      ctx.fillStyle = "rgba(10,17,25,0.28)"; ctx.fillRect(0, 0, w, h);
      ctx.globalCompositeOperation = "lighter";

      const N = nodes.length, px = new Array(N), py = new Array(N);
      for (let i = 0; i < N; i++) {
        const n = nodes[i];
        n.x += n.vx * dt; n.y += n.vy * dt;
        if (n.x < -M) n.x += w + 2*M; else if (n.x > w + M) n.x -= w + 2*M;
        if (n.y < -M) n.y += h + 2*M; else if (n.y > h + M) n.y -= h + 2*M;
        const par = 26 * (0.3 + n.z);
        px[i] = n.x + mouse.x * par; py[i] = n.y + mouse.y * par;
      }

      const D = Math.min(w, h) * 0.20 + 90;
      for (let i = 0; i < N; i++) for (let j = i + 1; j < N; j++) {
        const dx = px[i]-px[j], dy = py[i]-py[j], d = Math.hypot(dx, dy);
        if (d < D) {
          const a = 0.14 * (1 - d/D) * Math.min(nodes[i].b, nodes[j].b) * 1.3;
          ctx.strokeStyle = `rgba(110,150,235,${a})`;
          ctx.lineWidth = 0.6 + nodes[i].z; ctx.beginPath();
          ctx.moveTo(px[i], py[i]); ctx.lineTo(px[j], py[j]); ctx.stroke();
        }
      }

      acc += dt;
      if (acc > 0.22 && !REDUCE) {
        acc = 0;
        const a = (Math.random() * N) | 0;
        let best = -1, bd = D;
        for (let j = 0; j < N; j++) if (j !== a) {
          const d = Math.hypot(px[a]-px[j], py[a]-py[j]);
          if (d < bd) { bd = d; best = j; }
        }
        if (best >= 0) signals.push({ a, b: best, t: 0, sp: 0.7 + Math.random()*0.6 });
      }
      for (let s = signals.length - 1; s >= 0; s--) {
        const g = signals[s]; g.t += g.sp * dt;
        if (g.t >= 1) { signals.splice(s, 1); continue; }
        const x = px[g.a] + (px[g.b]-px[g.a])*g.t, y = py[g.a] + (py[g.b]-py[g.a])*g.t;
        glow(x, y, 10, "rgba(190,215,255,0.85)");
      }

      for (let i = 0; i < N; i++) {
        const n = nodes[i];
        const c = n.warm ? `rgba(245,150,80,${n.b})` : `rgba(120,165,255,${n.b})`;
        glow(px[i], py[i], 6 * n.r + 4, c);
        ctx.fillStyle = `rgba(234,241,255,${0.5 + n.b*0.5})`;
        ctx.beginPath(); ctx.arc(px[i], py[i], n.r, 0, TAU); ctx.fill();
      }
    }

    let last = performance.now(), running = true;
    function loop(now) {
      const dt = Math.min(0.05, (now - last) / 1000); last = now;
      if (running) frame(dt);
      if (!REDUCE) requestAnimationFrame(loop);
    }
    frame(0.016);
    if (REDUCE) { for (let i = 0; i < 30; i++) frame(0.016); }
    else requestAnimationFrame(loop);
    document.addEventListener("visibilitychange", () => { running = !document.hidden; last = performance.now(); });
  }
</script>
