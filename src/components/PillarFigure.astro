          }
          // pass 2: oscillator bars
          for (const p of P) {
            const hl = p._amp * 0.5, ax = Math.cos(p._th) * hl, ay = Math.sin(p._th) * hl, x = p._x, y = p._y;
            let wide, core;
            if (p.hue < 0) { wide = `hsla(210,25%,85%,${0.05 + 0.12 * a})`; core = `hsla(210,30%,92%,${0.3 + 0.5 * a})`; }
            else { wide = `hsla(${p.hue},85%,62%,${0.06 + 0.14 * a})`; core = `hsla(${p.hue},92%,${(62 + a * 8) | 0}%,${0.32 + 0.5 * a})`; }
            ctx.strokeStyle = wide; ctx.lineWidth = 4;
            ctx.beginPath(); ctx.moveTo(x - ax, y - ay); ctx.lineTo(x + ax, y + ay); ctx.stroke();
            ctx.strokeStyle = core; ctx.lineWidth = 2.1;
            ctx.beginPath(); ctx.moveTo(x - ax, y - ay); ctx.lineTo(x + ax, y + ay); ctx.stroke();
          }
        }

        // countdown bar → next brain formation (fills up to the moment it forms)
        ctx.globalCompositeOperation = "source-over";
        const barW = Math.min(g.gw * 0.4, 380), barH = Math.max(5, Math.min(g.gw, g.gh) * 0.014);
        const bx = g.gx + g.gw * 0.5 - barW / 2, by = g.gy + g.gh - barH - Math.max(12, g.gh * 0.06);
        ctx.fillStyle = "rgba(150,165,190,0.85)"; ctx.textAlign = "left"; ctx.textBaseline = "alphabetic";
        ctx.font = "500 11px system-ui,sans-serif";
        ctx.fillText("next emerge", bx, by - 7);
        ctx.fillStyle = "rgba(255,255,255,0.12)";
        rr(ctx, bx, by, barW, barH, barH / 2); ctx.fill();
        ctx.fillStyle = "hsla(305,85%,66%,0.95)";
        rr(ctx, bx, by, Math.max(barH, barW * barLevel), barH, barH / 2); ctx.fill();

        ctx.globalCompositeOperation = "source-over";
      };
    };
  }

  // ── Complex light dynamics: the effective-potential landscape of a rotating
  //    (Sun–planet) system. Dense contour basin + orbit + the five Lagrange points
  //    with librating Trojan/Greek clusters and green Coriolis-flow arrows. The
  //    whole basin slowly revolves. ──
  function trojanBeam(cv) {
    const { ctx, size } = setup(cv);
    let t = 0, off = null;
    const d = 0.6; // planet orbit radius (world units)
    const cluster = []; for (let i = 0; i < 24; i++) cluster.push([(Math.random() - 0.5) * 0.17, (Math.random() - 0.5) * 0.055, 0.4 + Math.random() * 0.7]);
    const arrows = []; for (let i = 0; i < 22; i++) arrows.push((i / 22) * TAU + 0.1);
    function buildField() {
      const N = 150, S = 660, m1 = 1, m2 = 0.05, soft = 0.006, Om2 = (m1 + m2) / (d * d * d);
      const pot = (x, y) => -m1 / Math.sqrt(x * x + y * y + soft) - m2 / Math.sqrt((x - d) * (x - d) + y * y + soft * 0.3) - 0.5 * Om2 * (x * x + y * y);
      const lo = -1.15, span = 2.3, gx = (i) => lo + span * i / (N - 1);
      const grid = new Float32Array(N * N); let mx = -1e9;
      for (let j = 0; j < N; j++) for (let i = 0; i < N; i++) { const v = pot(gx(i), gx(j)); grid[j * N + i] = v; if (isFinite(v) && v > mx) mx = v; }
      const vlo = -3.2, vhi = mx, nL = 40, levels = [];
      for (let l = 0; l < nL; l++) levels.push(vlo + (vhi - vlo) * Math.pow(l / (nL - 1), 1.5));
      off = document.createElement("canvas"); off.width = S; off.height = S;
      const o = off.getContext("2d"), toS = (x) => (x - lo) / span * S;
      const ip = (va, vb, a, b, L) => a + (b - a) * ((L - va) / (vb - va));
      o.lineWidth = 1;
      for (let li = 0; li < nL; li++) {
        const L = levels[li], f = li / (nL - 1);
        o.strokeStyle = `rgba(${(70 + f * 40) | 0},${(120 + f * 110) | 0},${(195 - f * 70) | 0},${0.12 + 0.16 * f})`;
        o.beginPath();
        for (let j = 0; j < N - 1; j++) for (let i = 0; i < N - 1; i++) {
          const x0 = gx(i), x1 = gx(i + 1), y0 = gx(j), y1 = gx(j + 1);
          const v00 = grid[j * N + i], v10 = grid[j * N + i + 1], v11 = grid[(j + 1) * N + i + 1], v01 = grid[(j + 1) * N + i];
          let c = 0; if (v00 > L) c |= 1; if (v10 > L) c |= 2; if (v11 > L) c |= 4; if (v01 > L) c |= 8;
          if (c === 0 || c === 15) continue;
          const eB = [toS(ip(v00, v10, x0, x1, L)), toS(y0)], eR = [toS(x1), toS(ip(v10, v11, y0, y1, L))], eT = [toS(ip(v01, v11, x0, x1, L)), toS(y1)], eL = [toS(x0), toS(ip(v00, v01, y0, y1, L))];
          const sg = (p, q) => { o.moveTo(p[0], p[1]); o.lineTo(q[0], q[1]); };
          switch (c) { case 1: case 14: sg(eL, eB); break; case 2: case 13: sg(eB, eR); break; case 3: case 12: sg(eL, eR); break; case 4: case 11: sg(eR, eT); break; case 6: case 9: sg(eB, eT); break; case 7: case 8: sg(eL, eT); break; case 5: sg(eL, eB); sg(eR, eT); break; case 10: sg(eB, eR); sg(eL, eT); break; }
        }
        o.stroke();
      }
    }
    return (dt) => {
      const { w, h } = size(); t += dt;
      const g = geoOf(w, h);
      const x0 = g.gx + g.gw * 0.05, x1 = g.gx + g.gw * 0.95, span = x1 - x0, cy = g.gy + g.gh * 0.5;
      const A = Math.min(g.gh * 0.2, g.gw * 0.06);
      const kk = 2 * Math.PI * 3, Om = t * 1.5, Sc = g.gh * 0.07; // 3 twists, rotate+propagate, gentle S
      const ax = (s) => x0 + s * span, ay = (s) => cy + Sc * Math.sin((s - 0.5) * Math.PI * 1.7);

      ctx.globalCompositeOperation = "source-over"; ctx.fillStyle = "#0a0a0f"; ctx.fillRect(0, 0, w, h);
      ctx.globalCompositeOperation = "lighter";

      // trapping-potential rings at the twist nodes (scroll forward)
      const dsN = 2 * Math.PI / kk, offN = (((Om / kk) % dsN) + dsN) % dsN;
      for (let s = offN; s <= 1.0; s += dsN) {
        const x = ax(s), y = ay(s);
        for (let k = 4; k >= 1; k--) { const ry = A * 0.28 * k; ctx.strokeStyle = `rgba(255,220,140,${0.04 + 0.05 * (4 - k)})`; ctx.lineWidth = 1; ctx.beginPath(); ctx.ellipse(x, y, ry * 0.4, ry, 0, 0, TAU); ctx.stroke(); }
      }

      // helix: yellow (phase 0) + blue (phase π), split into back/front for depth
      const beam = (ph, front, lw, col) => {
        ctx.strokeStyle = col; ctx.lineWidth = lw; ctx.lineCap = "round"; let on = false; ctx.beginPath();
        for (let s = 0; s <= 1.0001; s += 0.004) {
          const th = kk * s - Om + ph, depth = Math.cos(th);
          if ((front && depth < 0) || (!front && depth >= 0)) { on = false; continue; }
          const x = ax(s), y = ay(s) + A * Math.sin(th);
          on ? ctx.lineTo(x, y) : (ctx.moveTo(x, y), on = true);
        }
        ctx.stroke();
      };
      beam(0, false, 2.4, "rgba(255,200,80,0.18)");
      beam(Math.PI, false, 2.4, "rgba(90,170,255,0.18)");

      // circular rotation arrows between the rings (scroll forward)
      ctx.strokeStyle = "rgba(150,205,255,0.5)"; ctx.lineWidth = 1.4;
      for (let s = offN + dsN * 0.5; s <= 1.0; s += dsN) {
        const x = ax(s), y = ay(s), rx = A * 0.32, ry = A * 0.62, a1 = 2.1;
        ctx.beginPath(); ctx.ellipse(x, y, rx, ry, 0, -2.4, a1); ctx.stroke();
        const ex = x + rx * Math.cos(a1), ey = y + ry * Math.sin(a1), an = Math.atan2(ry * Math.cos(a1), -rx * Math.sin(a1));
        ctx.beginPath(); ctx.moveTo(ex, ey); ctx.lineTo(ex - Math.cos(an - 0.5) * 6, ey - Math.sin(an - 0.5) * 6); ctx.moveTo(ex, ey); ctx.lineTo(ex - Math.cos(an + 0.5) * 6, ey - Math.sin(an + 0.5) * 6); ctx.stroke();
      }

      // front (bright) strands over everything
      beam(0, true, 7, "rgba(255,200,80,0.22)"); beam(0, true, 3.4, "rgba(255,225,120,0.95)"); beam(0, true, 1.5, "rgba(255,250,225,0.92)");
      beam(Math.PI, true, 7, "rgba(90,170,255,0.22)"); beam(Math.PI, true, 3.4, "rgba(130,200,255,0.95)"); beam(Math.PI, true, 1.5, "rgba(225,245,255,0.92)");

      ctx.globalCompositeOperation = "source-over";
    };
  }

  // ── Complex light dynamics: a bound state in the continuum. A faint radiating
  //    continuum fills the field (gold crests / blue troughs); a bright localized
  //    mode sits inside it and oscillates, but its outgoing ripples cancel by
  //    destructive interference — so it never radiates away. ──
  function bic(cv) {
    const { ctx, size } = setup(cv);
    let t = 0;
    return (dt) => {
      const { w, h } = size(); t += dt;
      const g = geoOf(w, h);
      const cx = g.gx + g.gw * 0.5, cy = g.gy + g.gh * 0.5;
      const Rmax = Math.min(g.gw * 0.42, g.gh * 0.92), tilt = 0.42, om = t * 0.55;

      ctx.globalCompositeOperation = "source-over"; ctx.fillStyle = "#04060d"; ctx.fillRect(0, 0, w, h);
      ctx.globalCompositeOperation = "lighter";

      // faint radiating continuum (drifting bands)
      for (let n = 0; n < 3; n++) {
        const yy = cy + (n - 1) * g.gh * 0.3;
        ctx.strokeStyle = "rgba(70,110,180,0.05)"; ctx.lineWidth = g.gh * 0.13;
        ctx.beginPath(); for (let s = 0; s <= 1.0001; s += 0.02) { const x = g.gx + s * g.gw, y = yy + Math.sin(s * 20 - om * 2 + n) * g.gh * 0.03; s === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y); } ctx.stroke();
      }

      // wavefront ripples that emanate and fade before the edge (radiation cancels)
      const nR = 20;
      for (let n = 0; n < nR; n++) {
        const ph = ((n / nR) + om) % 1, rad = ph * Rmax, alpha = Math.min(1, ph * 7) * (1 - ph) * (1 - ph) * 0.7;
        if (alpha < 0.01) continue;
        ctx.strokeStyle = `rgba(120,215,255,${alpha})`; ctx.lineWidth = 1.6;
        ctx.beginPath();
        for (let a = 0; a <= 1.0001; a += 0.02) { const th = a * TAU, rr = rad * (1 + 0.05 * Math.cos(4 * th + om * 3)); const x = cx + Math.cos(th) * rr, y = cy + Math.sin(th) * rr * tilt; a === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y); }
        ctx.closePath(); ctx.stroke();
      }

      // brilliant trapped core, pulsing
      const pulse = 0.75 + 0.25 * Math.sin(t * 2.2);
      glow(ctx, cx, cy, Rmax * 0.22 * pulse, "rgba(90,180,255,0.28)");
      glow(ctx, cx, cy, Rmax * 0.1, "rgba(180,235,255,0.6)");
      glow(ctx, cx, cy, Rmax * 0.045, "rgba(255,252,245,0.98)");

      ctx.globalCompositeOperation = "source-over";
    };
  }

  const FACTORIES = {
    reconfigurable, reconfigurableSmooth, reconfigurablePixels, thermalize, thermalCompute,
    oscillators, oscillatorsWild, oscillatorsBrain, trojanBeam, bic,
    oscBrainCircuit: makeBrain(FIGBASE + "/research/figures/brain-circuit.webp"),
    oscBrainTop: makeBrain(FIGBASE + "/research/figures/brain-top.webp"),
    oscBrainSide: makeBrain(FIGBASE + "/research/figures/brain-side.png"),
  };

  const active = new Set();
  document.querySelectorAll("canvas[data-fig]").forEach((cv) => {
    const make = FACTORIES[cv.dataset.fig];
    if (!make) return;
    cv._step = make(cv);
    const io = new IntersectionObserver((es) => {
      for (const e of es) { if (e.isIntersecting) active.add(cv); else active.delete(cv); }
    }, { threshold: 0.05 });
    io.observe(cv);
  });
  let last = performance.now();
  function loop(now) {
    const dt = Math.min(0.05, (now - last) / 1000); last = now;
    for (const cv of active) { cv._step(dt); if (REDUCE) active.delete(cv); }
    requestAnimationFrame(loop);
  }
  requestAnimationFrame(loop);
</script>
