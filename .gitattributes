# Normalize line endings to LF in the repository AND the working copy.
# This overrides Windows' automatic CRLF conversion, so the
# "LF will be replaced by CRLF" warnings stop and files stay consistent
# across machines. (LF is the standard for web/code projects.)
* text=auto eol=lf

# Binary assets: never touch their bytes / never convert line endings.
*.woff2 binary
*.woff  binary
*.ttf   binary
*.otf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
