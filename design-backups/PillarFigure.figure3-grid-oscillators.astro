---
// src/components/PillarFigure.astro
// A dark-native animated figure used as a research pillar's hero. Pass a `kind`
// that selects one of the canvas animations in the registry below. Self-hosted,
// vanilla JS, pauses off-screen, honors prefers-reduced-motion.
interface Props { kind: string; }
const { kind } = Astro.props;
---

<canvas class="pillar-fig" data-fig={kind} aria-hidden="true"></canvas>

<style>
  .pillar-fig { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
</style>

<script>
  const REDUCE = matchMedia("(prefers-reduced-motion: reduce)").matches;
  const DPR = Math.min(2, window.devicePixelRatio || 1);
  const TAU = Math.PI * 2;

  function setup(cv) {
    const ctx = cv.getContext("2d");
    let w = 0, h = 0;
    function fit() {
      const r = cv.getBoundingClientRect();
      w = Math.max(1, Math.round(r.width)); h = Math.max(1, Math.round(r.height));
      cv.width = w * DPR; cv.height = h * DPR;
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
    }
    fit();
    new ResizeObserver(fit).observe(cv);
    return { ctx, size: () => ({ w, h }) };
  }
  function glow(ctx, x, y, r, color) {
    const g = ctx.createRadialGradient(x, y, 0, x, y, r);
    g.addColorStop(0, color); g.addColorStop(1, "rgba(0,0,0,0)");
    ctx.fillStyle = g; ctx.beginPath(); ctx.arc(x, y, r, 0, TAU); ctx.fill();
  }
  function rr(ctx, x, y, w, h, r) {
    r = Math.min(r, w / 2, h / 2);
    ctx.beginPath();
    ctx.moveTo(x + r, y);
    ctx.arcTo(x + w, y, x + w, y + h, r);
    ctx.arcTo(x + w, y + h, x, y + h, r);
    ctx.arcTo(x, y + h, x, y, r);
    ctx.arcTo(x, y, x + w, y, r);
    ctx.closePath();
  }

  // ── shared: the reconfigurable-photonics scene ──────────────────────────────
  const smooth = (v) => v * v * (3 - 2 * v);
  const clamp01 = (v) => Math.max(0, Math.min(1, v));
  // continuous refractive-index field n(x, y, t) in [0,1]
  const fieldR = (nx, ny, tt) => 0.5 + (
    Math.sin(6.2 * nx + tt * 0.7) * Math.cos(5.0 * ny - tt * 0.5)
    + 0.7 * Math.sin(3.3 * nx - 2.4 * ny + tt * 0.9)
    + 0.5 * Math.cos(4.1 * ny + tt * 0.45)
  ) / 3.2;

  function geoOf(w, h) {
    const topPad = h * 0.22, botPad = h * 0.10, sidePad = w * 0.05;
    const gx = sidePad, gy = topPad, gw = w - 2 * sidePad, gh = h - topPad - botPad;
    return { w, h, gx, gy, gw, gh, PX: (nx) => gx + nx * gw, PY: (ny) => gy + ny * gh };
  }

  function drawProjector(ctx, g, t) {
    const { w, h, gx, gy, gw, gh } = g;
    const px = w * 0.5, py = h * 0.06;
    const cone = ctx.createLinearGradient(px, py, px, gy + gh * 0.2);
    cone.addColorStop(0, "rgba(162,168,255,0.28)");
    cone.addColorStop(1, "rgba(120,160,255,0.02)");
    ctx.fillStyle = cone;
    ctx.beginPath();
    ctx.moveTo(px - 11, py + 9);
    ctx.lineTo(gx + gw * 0.30, gy);
    ctx.lineTo(gx + gw * 0.70, gy);
    ctx.lineTo(px + 11, py + 9);
    ctx.closePath(); ctx.fill();
    ctx.globalCompositeOperation = "lighter";
    for (let s = 0; s < 3; s++) {
      const sx = gx + gw * (0.34 + s * 0.16 + 0.02 * Math.sin(t * 0.9 + s));
      glow(ctx, sx, gy + 2, 18, "rgba(175,190,255,0.5)");
    }
    ctx.globalCompositeOperation = "source-over";
    ctx.fillStyle = "#2c3a55"; rr(ctx, px - 21, py - 8, 42, 18, 4); ctx.fill();
    ctx.fillStyle = "#a68bff"; rr(ctx, px - 5, py + 8, 10, 4, 2); ctx.fill();
  }

  function drawRays(ctx, g, t) {
    const { PX, PY } = g;
    const grad = (nx, ny) => {
      const e = 0.01;
      return [(fieldR(nx + e, ny, t) - fieldR(nx - e, ny, t)) / (2 * e),
              (fieldR(nx, ny + e, t) - fieldR(nx, ny - e, t)) / (2 * e)];
    };
    const starts = [0.26, 0.5, 0.74];
    starts.forEach((y0, ri) => {
      let x = 0, y = y0, vx = 1, vy = 0;
      const pts = [[x, y]];
      for (let s = 0; s < 130 && x < 1.001; s++) {
        const [gxx, gyy] = grad(x, y);
        vx += gxx * 0.002; vy += gyy * 0.009;
        const m = Math.hypot(vx, vy) || 1; vx /= m; vy /= m;
        x += vx * 0.010; y += vy * 0.010;
        if (y < 0.02) { pts.push([x, 0.02]); break; }
        if (y > 0.98) { pts.push([x, 0.98]); break; }
        pts.push([x, y]);
      }
      const path = () => { ctx.beginPath(); pts.forEach((p, k) => { const X = PX(p[0]), Y = PY(p[1]); k ? ctx.lineTo(X, Y) : ctx.moveTo(X, Y); }); };
      ctx.globalCompositeOperation = "lighter";
      ctx.strokeStyle = "rgba(140,185,255,0.16)"; ctx.lineWidth = 5; path(); ctx.stroke();
      ctx.strokeStyle = "rgba(208,230,255,0.78)"; ctx.lineWidth = 1.8; path(); ctx.stroke();
      if (!REDUCE) {
        const prog = (t * 0.30 + ri * 0.33) % 1;
        const pt = pts[Math.floor(prog * (pts.length - 1))];
        if (pt) glow(ctx, PX(pt[0]), PY(pt[1]), 11, "rgba(226,238,255,0.95)");
      }
      glow(ctx, PX(0), PY(y0), 7, "rgba(150,185,255,0.85)");
      const end = pts[pts.length - 1];
      if (end) glow(ctx, PX(end[0]), PY(end[1]), 7, "rgba(255,255,255,0.9)");
      ctx.globalCompositeOperation = "source-over";
    });
  }

  // ── variant A: discrete "pixel" index cells (the saved Figure 1) ──
  function reconfigurable(cv) {
    const { ctx, size } = setup(cv);
    const cols = 22, rows = 9;
    let t = 0;
    return (dt) => {
      const { w, h } = size(); t += dt;
      const g = geoOf(w, h);
      ctx.globalCompositeOperation = "source-over";
      ctx.fillStyle = "#0a1119"; ctx.fillRect(0, 0, w, h);
      drawProjector(ctx, g, t);
      const cw = g.gw / cols, ch = g.gh / rows;
      ctx.globalCompositeOperation = "lighter";
      const pad = Math.min(cw, ch) * 0.12, rad = Math.min(cw, ch) * 0.22;
      for (let j = 0; j < rows; j++) for (let i = 0; i < cols; i++) {
        const v = smooth(clamp01(fieldR((i + 0.5) / cols, (j + 0.5) / rows, t)));
        const x = g.gx + i * cw, y = g.gy + j * ch;
        const R = 45 + v * 115, G = 100 + v * 60, B = 205 + v * 50;
        ctx.fillStyle = `rgba(${R | 0},${G | 0},${B | 0},${0.05 + v * 0.48})`;
        rr(ctx, x + pad, y + pad, cw - 2 * pad, ch - 2 * pad, rad); ctx.fill();
      }
      ctx.globalCompositeOperation = "source-over";
      drawRays(ctx, g, t);
    };
  }

  // ── variant B: continuous, pixel-less index field (the test) ──
  function reconfigurableSmooth(cv) {
    const { ctx, size } = setup(cv);
    let t = 0;
    const bw = 180, bh = 80, buf = document.createElement("canvas");
    buf.width = bw; buf.height = bh;
    const bctx = buf.getContext("2d"), img = bctx.createImageData(bw, bh);
    return (dt) => {
      const { w, h } = size(); t += dt;
      const g = geoOf(w, h);
      ctx.globalCompositeOperation = "source-over";
      ctx.fillStyle = "#0a1119"; ctx.fillRect(0, 0, w, h);
      drawProjector(ctx, g, t);
      // smooth continuous index landscape (dark navy → periwinkle)
      const d = img.data;
      for (let yy = 0; yy < bh; yy++) for (let xx = 0; xx < bw; xx++) {
        const v = smooth(clamp01(fieldR(xx / (bw - 1), yy / (bh - 1), t)));
        const p = (yy * bw + xx) * 4;
        d[p] = 14 + v * 146; d[p + 1] = 24 + v * 131; d[p + 2] = 40 + v * 215; d[p + 3] = 255;
      }
      bctx.putImageData(img, 0, 0);
      ctx.save();
      rr(ctx, g.gx, g.gy, g.gw, g.gh, Math.min(g.gw, g.gh) * 0.05); ctx.clip();
      ctx.imageSmoothingEnabled = true;
      ctx.drawImage(buf, g.gx, g.gy, g.gw, g.gh);
      ctx.restore();
      drawRays(ctx, g, t);
    };
  }

  // ── variant C: fine "small-pixel" index grid (SLM-like) ──
  function reconfigurablePixels(cv) {
    const { ctx, size } = setup(cv);
    const cols = 56, rows = 22;
    let t = 0;
    return (dt) => {
      const { w, h } = size(); t += dt;
      const g = geoOf(w, h);
      ctx.globalCompositeOperation = "source-over";
      ctx.fillStyle = "#0a1119"; ctx.fillRect(0, 0, w, h);
      drawProjector(ctx, g, t);
      const cw = g.gw / cols, ch = g.gh / rows;
      ctx.globalCompositeOperation = "lighter";
      const gap = Math.max(0.5, Math.min(cw, ch) * 0.16), rad = Math.min(cw, ch) * 0.3;
      for (let j = 0; j < rows; j++) for (let i = 0; i < cols; i++) {
        const v = smooth(clamp01(fieldR((i + 0.5) / cols, (j + 0.5) / rows, t)));
        const x = g.gx + i * cw, y = g.gy + j * ch;
        const R = 45 + v * 115, G = 100 + v * 60, B = 205 + v * 50;
        ctx.fillStyle = `rgba(${R | 0},${G | 0},${B | 0},${0.05 + v * 0.5})`;
        rr(ctx, x + gap / 2, y + gap / 2, cw - gap, ch - gap, rad); ctx.fill();
      }
      ctx.globalCompositeOperation = "source-over";
      drawRays(ctx, g, t);
    };
  }

  // ── Optical thermodynamic computing: multimode light thermalizes / self-cleans
  //    warm speckle (left, hot) condenses into a cool clean beam (right). ──
  function thermalize(cv) {
    const { ctx, size } = setup(cv);
    const bw = 190, bh = 84, buf = document.createElement("canvas");
    buf.width = bw; buf.height = bh;
    const bctx = buf.getContext("2d"), img = bctx.createImageData(bw, bh);
    const modes = [
      { kx: 3.1, ky: 2.2, ph: 0.0, sp: 1.1 },
      { kx: 5.0, ky: 1.4, ph: 1.7, sp: 0.9 },
      { kx: 2.0, ky: 4.1, ph: 3.2, sp: 1.4 },
      { kx: 6.3, ky: 3.0, ph: 0.9, sp: 0.7 },
      { kx: 4.2, ky: 5.2, ph: 2.4, sp: 1.2 },
      { kx: 1.5, ky: 6.0, ph: 4.1, sp: 1.0 },
    ];
    let t = 0;
    return (dt) => {
      const { w, h } = size(); t += dt;
      const g = geoOf(w, h);
      ctx.globalCompositeOperation = "source-over";
      ctx.fillStyle = "#0a1119"; ctx.fillRect(0, 0, w, h);
      for (const m of modes) m.ph += dt * m.sp;

      const d = img.data;
      for (let yy = 0; yy < bh; yy++) for (let xx = 0; xx < bw; xx++) {
        const nx = xx / (bw - 1);            // 0..1 propagation (left→right)
        const ny = (yy / (bh - 1)) * 2 - 1;  // -1..1 transverse
        const c = smooth(nx);                // "cleanliness" grows along propagation
        const tt = 1 - c;                    // temperature (hot at input)
        const sig = 0.5 - 0.34 * c;          // beam narrows as it condenses
        const gauss = Math.exp(-(ny * ny) / (2 * sig * sig));
        let sp = 0;
        for (const m of modes) sp += Math.cos(m.kx * nx * 7 + m.ky * ny * 3.2 + m.ph);
        sp /= modes.length;                  // -1..1
        let I = gauss * (1 + tt * sp * 0.9) * (0.5 + 0.8 * c);
        I = Math.max(0, Math.min(1, I));
        const p = (yy * bw + xx) * 4;
        d[p] = I * (255 * tt + 120 * (1 - tt));
        d[p + 1] = I * (140 * tt + 175 * (1 - tt));
        d[p + 2] = I * (70 * tt + 255 * (1 - tt));
        d[p + 3] = 255;
      }
      bctx.putImageData(img, 0, 0);
      ctx.save();
      rr(ctx, g.gx, g.gy, g.gw, g.gh, Math.min(g.gw, g.gh) * 0.05); ctx.clip();
      ctx.imageSmoothingEnabled = true;
      ctx.drawImage(buf, g.gx, g.gy, g.gw, g.gh);
      ctx.restore();
    };
  }

  // ── Optical thermodynamic computing: thermalized light on a chip; its mode
  //    amplitudes random-walk (Ornstein–Uhlenbeck) and the trajectory's
  //    collective covariance ellipse IS the matrix inverse (Σ ∝ A⁻¹). ──
  function thermalCompute(cv) {
    const { ctx, size } = setup(cv);
    const A = [[1.3, -0.75], [-0.75, 1.05]]; // "Hamiltonian"; covariance ∝ A⁻¹
    let a0 = 3.0, a1 = -3.2;                  // start off in a corner (the "Initial")
    const trail = [], MAXT = 760, grid = 4;
    let t = 0;
    const gauss = () => (Math.random() + Math.random() + Math.random() - 1.5);
    // optional chip bitmap (drop your render at public/research/thermal-chip.png);
    // falls back to the schematic below if the file is missing.
    const BASE = import.meta.env.BASE_URL.replace(/\/+$/, "");
    const chip = new Image();
    let chipReady = false;
    chip.onload = () => { chipReady = true; };
    chip.src = BASE + "/research/figures/thermal-chip.png";
    function ou() {
      for (let s = 0; s < 2; s++) {
        const f0 = -(A[0][0] * a0 + A[0][1] * a1);
        const f1 = -(A[1][0] * a0 + A[1][1] * a1);
        a0 += f0 * 0.06 + gauss() * 0.33;
        a1 += f1 * 0.06 + gauss() * 0.33;
      }
      trail.push([a0, a1]); if (trail.length > MAXT) trail.shift();
    }
    return (dt) => {
      const { w, h } = size(); t += dt;
      ctx.globalCompositeOperation = "source-over";
      ctx.fillStyle = "#0a1119"; ctx.fillRect(0, 0, w, h);

      if (REDUCE) { if (!trail.length) for (let k = 0; k < MAXT; k++) ou(); }
      else ou();

      // ── layout: chip panel (left) + phase space (right) ──
      const fw = Math.min(w * 0.30, h * 0.74), fh = fw;
      const fx = w * 0.05, fy = (h - fh) / 2, fcy = fy + fh / 2;
      const psCx = w * 0.68, psCy = h * 0.50;
      const psR = Math.min(w * 0.24, h * 0.44), scale = psR / 2.6;
      const MX = (v) => psCx + v * scale, MY = (v) => psCy - v * scale;

      // chip: framed bitmap (cover-fit) if provided, else schematic
      if (chipReady) {
        ctx.globalCompositeOperation = "source-over";
        ctx.save();
        rr(ctx, fx, fy, fw, fh, 16); ctx.clip();
        const ar = chip.width / chip.height || 1, far = fw / fh;
        let dw = fw, dh = fh, dx = fx, dy = fy;
        if (ar > far) { dh = fh; dw = fh * ar; dx = fx - (dw - fw) / 2; }
        else { dw = fw; dh = fw / ar; dy = fy - (dh - fh) / 2; }
        ctx.drawImage(chip, dx, dy, dw, dh);
        ctx.restore();
        ctx.strokeStyle = "rgba(255,255,255,0.14)"; ctx.lineWidth = 1;
        rr(ctx, fx + 0.5, fy + 0.5, fw - 1, fh - 1, 16); ctx.stroke();
      } else {
        ctx.globalCompositeOperation = "lighter";
        glow(ctx, fx + fw / 2, fcy - fh * 0.28, fw * 0.42, "rgba(255,150,60,0.30)");
        glow(ctx, fx + fw / 2, fcy - fh * 0.28, fw * 0.24, "rgba(255,214,130,0.5)");
        const cell = fw * 0.14;
        for (let j = 0; j < grid; j++) for (let i = 0; i < grid; i++) {
          const x = fx + fw / 2 + (i - (grid - 1) / 2) * cell;
          const y = fcy + fh * 0.12 + (j - (grid - 1) / 2) * cell * 0.7;
          const v = 0.5 + 0.5 * Math.sin(t * 1.3 + i * 0.8 + j * 0.6);
          glow(ctx, x, y, cell * 0.5, `rgba(${120 + (v * 135) | 0},${150 + (v * 40) | 0},255,0.5)`);
        }
      }

      // readout wires: two DIFFERENT chip output ports → the two phase-space axes,
      // with fast-flowing "readout" photons that keep pace with the trajectory.
      ctx.globalCompositeOperation = "lighter";
      const wire = (px, py, x1, y1, ctrlDY) => {
        const cx = (px + x1) / 2, cy = (py + y1) / 2 + ctrlDY;
        ctx.strokeStyle = "rgba(120,190,255,0.26)"; ctx.lineWidth = 2.2;
        ctx.beginPath(); ctx.moveTo(px, py); ctx.quadraticCurveTo(cx, cy, x1, y1); ctx.stroke();
        glow(ctx, px, py, 6, "rgba(150,200,255,0.6)"); // output-port tap
        if (!REDUCE) for (let k = 0; k < 5; k++) {
          const u = (t * 2.2 + k / 5) % 1, iu = 1 - u;
          const mx = iu * iu * px + 2 * iu * u * cx + u * u * x1;
          const my = iu * iu * py + 2 * iu * u * cy + u * u * y1;
          glow(ctx, mx, my, 6.5, "rgba(205,232,255,0.85)");
        }
      };
      wire(fx + fw, fcy + fh * 0.14, psCx - psR * 1.02, psCy, -h * 0.05);   // port A → x-axis: Re{aᵢ}
      wire(fx + fw * 0.90, fy + fh * 0.93, psCx, psCy + psR * 1.02, h * 0.12);    // port B → y-axis: Re{aⱼ}

      // soft bloom behind the phase-space cloud so it reads as boldly as the render
      ctx.globalCompositeOperation = "lighter";
      glow(ctx, psCx, psCy, psR * 1.2, "rgba(55,110,225,0.16)");

      // faint axes
      ctx.globalCompositeOperation = "source-over";
      ctx.strokeStyle = "rgba(255,255,255,0.12)"; ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(psCx - psR, psCy); ctx.lineTo(psCx + psR, psCy);
      ctx.moveTo(psCx, psCy - psR); ctx.lineTo(psCx, psCy + psR); ctx.stroke();

      ctx.globalCompositeOperation = "lighter";
      // random trajectory — glow pass + bright core (full tangle, then recent)
      const drawTrail = (from, lw, col) => {
        ctx.strokeStyle = col; ctx.lineWidth = lw; ctx.beginPath();
        for (let k = from; k < trail.length; k++) { const X = MX(trail[k][0]), Y = MY(trail[k][1]); k === from ? ctx.moveTo(X, Y) : ctx.lineTo(X, Y); }
        ctx.stroke();
      };
      drawTrail(0, 3.4, "rgba(90,150,255,0.14)");
      drawTrail(0, 1.3, "rgba(150,195,255,0.55)");
      const st = Math.max(0, trail.length - 80);
      drawTrail(st, 4.2, "rgba(160,205,255,0.20)");
      drawTrail(st, 1.9, "rgba(220,238,255,0.97)");

      // covariance ellipse (∝ A⁻¹) = the matrix inverse — vivid gold with bloom
      const ellipse = (lw, col) => {
        ctx.strokeStyle = col; ctx.lineWidth = lw; ctx.beginPath();
        for (let k = 0; k <= 72; k++) {
          const th = (k / 72) * TAU, ux = Math.cos(th), uy = Math.sin(th);
          const uAu = A[0][0] * ux * ux + 2 * A[0][1] * ux * uy + A[1][1] * uy * uy;
          const r = Math.sqrt(1.7 / uAu);
          const X = MX(r * ux), Y = MY(r * uy);
          k ? ctx.lineTo(X, Y) : ctx.moveTo(X, Y);
        }
        ctx.closePath(); ctx.stroke();
      };
      ellipse(6, "rgba(255,165,70,0.20)");
      ellipse(2.4, "rgba(255,192,100,0.98)");

      // current point
      glow(ctx, MX(a0), MY(a1), 14, "rgba(226,239,255,0.98)");
      ctx.fillStyle = "#f2f7ff"; ctx.beginPath(); ctx.arc(MX(a0), MY(a1), 2.9, 0, TAU); ctx.fill();

      ctx.globalCompositeOperation = "source-over";
    };
  }

  // ── Analog neural networks: a lattice of coupled oscillators (Kuramoto) whose
  //    phases self-organize into shifting domains — collective analog computation. ──
  function oscillators(cv) {
    const { ctx, size } = setup(cv);
    const cols = 20, rows = 7, N = cols * rows;
    const phase = new Float32Array(N), omega = new Float32Array(N), np = new Float32Array(N);
    const gr = () => (Math.random() + Math.random() + Math.random() - 1.5);
    for (let i = 0; i < N; i++) { phase[i] = Math.random() * TAU; omega[i] = 0.7 + gr() * 0.55; }
    const K = 1.3;
    const idx = (c, r) => r * cols + c;
    return (dt) => {
      const { w, h } = size();
      const g = geoOf(w, h);
      const cw = g.gw / cols, ch = g.gh / rows;

      if (!REDUCE) for (let s = 0; s < 2; s++) {
        for (let r = 0; r < rows; r++) for (let c = 0; c < cols; c++) {
          const i = idx(c, r); let sum = 0;
          if (c > 0) sum += Math.sin(phase[idx(c - 1, r)] - phase[i]);
          if (c < cols - 1) sum += Math.sin(phase[idx(c + 1, r)] - phase[i]);
          if (r > 0) sum += Math.sin(phase[idx(c, r - 1)] - phase[i]);
          if (r < rows - 1) sum += Math.sin(phase[idx(c, r + 1)] - phase[i]);
          np[i] = phase[i] + (omega[i] + K * sum) * dt * 0.5 + gr() * 0.015;
        }
        phase.set(np);
      }

      ctx.globalCompositeOperation = "source-over";
      ctx.fillStyle = "#0a1119"; ctx.fillRect(0, 0, w, h);
      ctx.globalCompositeOperation = "lighter";

      // coupling traces (right & down) — brighter where neighbours are in phase
      ctx.lineWidth = 1;
      for (let r = 0; r < rows; r++) for (let c = 0; c < cols; c++) {
        const i = idx(c, r), x = g.gx + (c + 0.5) * cw, y = g.gy + (r + 0.5) * ch;
        if (c < cols - 1) { const coh = 0.5 + 0.5 * Math.cos(phase[idx(c + 1, r)] - phase[i]); ctx.strokeStyle = `rgba(150,185,255,${0.04 + coh * 0.16})`; ctx.beginPath(); ctx.moveTo(x, y); ctx.lineTo(g.gx + (c + 1.5) * cw, y); ctx.stroke(); }
        if (r < rows - 1) { const coh = 0.5 + 0.5 * Math.cos(phase[idx(c, r + 1)] - phase[i]); ctx.strokeStyle = `rgba(150,185,255,${0.04 + coh * 0.16})`; ctx.beginPath(); ctx.moveTo(x, y); ctx.lineTo(x, g.gy + (r + 1.5) * ch); ctx.stroke(); }
      }
      // each oscillator = a small dial with a rotating phasor hand (angle = phase);
      // synchronized oscillators point the same way (and share colour)
      const rad = Math.min(cw, ch) * 0.32;
      for (let r = 0; r < rows; r++) for (let c = 0; c < cols; c++) {
        const i = idx(c, r), x = g.gx + (c + 0.5) * cw, y = g.gy + (r + 0.5) * ch;
        const th = phase[i];
        const hue = ((((th % TAU) + TAU) % TAU) / TAU) * 360;
        ctx.strokeStyle = "rgba(130,160,215,0.16)"; ctx.lineWidth = 1;
        ctx.beginPath(); ctx.arc(x, y, rad, 0, TAU); ctx.stroke();
        const hx = x + rad * Math.cos(th), hy = y + rad * Math.sin(th);
        ctx.strokeStyle = `hsla(${hue | 0},88%,66%,0.95)`; ctx.lineWidth = 2;
        ctx.beginPath(); ctx.moveTo(x, y); ctx.lineTo(hx, hy); ctx.stroke();
        glow(ctx, hx, hy, rad * 0.8, `hsla(${hue | 0},90%,66%,0.45)`);
        ctx.fillStyle = "rgba(220,232,255,0.8)"; ctx.beginPath(); ctx.arc(x, y, 1.6, 0, TAU); ctx.fill();
      }
      ctx.globalCompositeOperation = "source-over";
    };
  }

  const FACTORIES = { reconfigurable, reconfigurableSmooth, reconfigurablePixels, thermalize, thermalCompute, oscillators };

  const active = new Set();
  document.querySelectorAll("canvas[data-fig]").forEach((cv) => {
    const make = FACTORIES[cv.dataset.fig];
    if (!make) return;
    cv._step = make(cv);
    const io = new IntersectionObserver((es) => {
      for (const e of es) { if (e.isIntersecting) active.add(cv); else active.delete(cv); }
    }, { threshold: 0.05 });
    io.observe(cv);
  });
  let last = performance.now();
  function loop(now) {
    const dt = Math.min(0.05, (now - last) / 1000); last = now;
    for (const cv of active) { cv._step(dt); if (REDUCE) active.delete(cv); }
    requestAnimationFrame(loop);
  }
  requestAnimationFrame(loop);
</script>
