---
// src/pages/research/[slug].astro — one research pillar's subpage
import BaseLayout from "../../layouts/BaseLayout.astro";
import Figure from "../../components/Figure.astro";
import PillarFigure from "../../components/PillarFigure.astro";
import LagrangeSurface from "../../components/LagrangeSurface.astro";
import BICFilm from "../../components/BICFilm.astro";
import { research } from "../../data/research";

export function getStaticPaths() {
  return research.map((pillar) => ({
    params: { slug: pillar.slug },
    props: { pillar },
  }));
}

const { pillar } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/+$/, "");
---

<BaseLayout title={`${pillar.title} — Research`} description={pillar.tagline}>
  <main class="wrap">
    <a class="back" href={`${BASE}/research`}>&larr; All research</a>

    <header class="pillar-head">
      <div class="eyebrow">Research pillar</div>
      <h1>{pillar.title}</h1>
      <p class="lead">{pillar.tagline}</p>
    </header>

    {
      pillar.slug === "complex-light-dynamics" ? (
        <div class="cld-panels">
          <figure class="cld-panel">
            <LagrangeSurface height={380} />
            <figcaption>Trapping light at a Lagrange point (Trojan beam)</figcaption>
          </figure>
          <figure class="cld-panel">
            <div class="cld-bic"><BICFilm controls={false} /></div>
            <figcaption>A bound state in the continuum</figcaption>
            <button type="button" class="film-open">
              <span class="film-tri" aria-hidden="true">&#9654;</span> Watch the full animation
            </button>
          </figure>
        </div>
      ) : (
        <div class="hero-media">
          {
            pillar.animation ? (
              <PillarFigure kind={pillar.animation} />
            ) : (
              <Fragment>
                <span class="hero-fallback" aria-hidden="true">{pillar.title}</span>
                <img
                  src={BASE + pillar.image}
                  alt={pillar.alt ?? pillar.title}
                  onerror="this.style.display='none'"
                />
              </Fragment>
            )
          }
        </div>
      )
    }

    {
      pillar.slug === "complex-light-dynamics" && (
        <div class="film-modal" id="filmModal" hidden>
          <div class="film-backdrop" data-close></div>
          <div
            class="film-dialog"
            role="dialog"
            aria-modal="true"
            aria-label="Bound states in the continuum — full animation"
          >
            <button type="button" class="film-close" data-close aria-label="Close">&times;</button>
            <BICFilm />
          </div>
        </div>
      )
    }

    <div class="prose">
      {pillar.description.map((para) => <p>{para}</p>)}
    </div>

    {
      pillar.figures && pillar.figures.length > 0 && (
        <section class="figures" aria-label="Figures">
          <h2 class="section-heading">Figures</h2>
          <div class="fig-grid">
            {pillar.figures.map((f) => <Figure src={f.src} caption={f.caption} alt={f.alt} />)}
          </div>
        </section>
      )
    }

    {
      pillar.references && pillar.references.length > 0 && (
        <section class="refs" aria-label="Further reading">
          <h2 class="section-heading">Further reading</h2>
          <ol class="ref-list">
            {pillar.references.map((r) => (
              <li>
                <div class="r-body">
                  <div class="r-title">
                    {r.url ? <a href={r.url} target="_blank" rel="noopener">{r.title}</a> : r.title}
                  </div>
                  <div class="r-meta">{r.authors} · <span class="r-venue">{r.venue}</span>, {r.year}</div>
                </div>
              </li>
            ))}
          </ol>
        </section>
      )
    }
  </main>

  {
    pillar.slug === "complex-light-dynamics" && (
      <script is:inline>
        (function () {
          var modal = document.getElementById("filmModal");
          if (!modal) return;
          var lastFocus = null;
          function openFilm() {
            lastFocus = document.activeElement;
            modal.hidden = false;
            document.body.style.overflow = "hidden";
            var c = modal.querySelector(".film-close");
            if (c) c.focus();
          }
          function closeFilm() {
            modal.hidden = true;
            document.body.style.overflow = "";
            if (lastFocus && lastFocus.focus) lastFocus.focus();
          }
          var btns = document.querySelectorAll(".film-open");
          for (var i = 0; i < btns.length; i++) {
            btns[i].addEventListener("click", function () { openFilm(); });
          }
          modal.addEventListener("click", function (e) {
            if (e.target && e.target.hasAttribute && e.target.hasAttribute("data-close")) closeFilm();
          });
          document.addEventListener("keydown", function (e) {
            if (!modal.hidden && (e.key === "Escape" || e.key === "Esc")) closeFilm();
          });
        })();
      </script>
    )
  }
</BaseLayout>

<style>
  .back {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.18s;
  }
  .back:hover,
  .back:focus-visible { color: var(--ink); outline: none; }

  .pillar-head { margin-bottom: 1.75rem; }
  .pillar-head h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2.1rem, 5vw, 3.1rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0.3rem 0 0.7rem;
  }

  .hero-media {
    position: relative;
    aspect-ratio: 21 / 9;
    border-radius: 12px;
    overflow: hidden;
    background: var(--accent-soft);
    margin-bottom: clamp(1.75rem, 4vw, 2.75rem);
  }
  .cld-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1rem, 2.5vw, 1.6rem);
    align-items: start;
    margin-bottom: clamp(1.75rem, 4vw, 2.75rem);
  }
  .cld-panel { margin: 0; }
  .cld-panel figcaption { color: var(--muted); font-size: 0.85rem; margin-top: 0.6rem; text-align: center; }
  .cld-bic { position: relative; height: 380px; border-radius: 12px; overflow: hidden; background: #04060d; }

  /* "Watch the full animation" button under the BIC panel */
  .film-open {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: center;
    margin-top: 0.7rem;
    padding: 0.5rem 0.95rem;
    background: var(--accent-soft);
    color: var(--ink);
    border: 1px solid var(--line);
    border-radius: 999px;
    font: inherit;
    font-size: 0.86rem;
    cursor: pointer;
    transition: border-color 0.18s, color 0.18s, background 0.18s;
  }
  .cld-panel { display: flex; flex-direction: column; }
  .cld-panel .cld-bic { width: 100%; }
  .film-open:hover,
  .film-open:focus-visible { border-color: var(--accent); color: var(--accent); outline: none; }
  .film-tri { color: var(--accent); font-size: 0.72em; line-height: 1; }

  /* Full-size film lightbox (film loads only when opened) */
  .film-modal { position: fixed; inset: 0; z-index: 1000; display: grid; place-items: center; }
  .film-modal[hidden] { display: none; }
  .film-backdrop { position: absolute; inset: 0; background: rgba(4, 6, 13, 0.82); backdrop-filter: blur(3px); }
  .film-dialog {
    position: relative;
    width: min(94vw, calc((92vh - 3rem) * 16 / 9));
    aspect-ratio: 16 / 9;
    background: #07080d;
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.55);
  }
  .film-close {
    position: absolute;
    top: 10px;
    right: 12px;
    z-index: 2;
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    background: rgba(7, 8, 13, 0.7);
    color: #e8eef8;
    border: 1px solid rgba(232, 238, 248, 0.22);
    border-radius: 50%;
    font-size: 1.15rem;
    line-height: 1;
    cursor: pointer;
    transition: background 0.18s, border-color 0.18s;
  }
  .film-close:hover,
  .film-close:focus-visible { background: rgba(7, 8, 13, 0.95); border-color: rgba(232, 238, 248, 0.5); outline: none; }
  @media (max-width: 640px) { .cld-panels { grid-template-columns: 1fr; } }
  .hero-fallback {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: 1rem;
    text-align: center;
    font-family: var(--serif);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    color: var(--accent);
    opacity: 0.5;
  }
  .hero-media img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .prose {
    max-width: 68ch;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .prose p {
    color: var(--ink);
    font-size: 1.08rem;
    line-height: 1.7;
  }
  .prose p + p { margin-top: 1.1rem; }

  .figures { margin-bottom: clamp(2.5rem, 5vw, 3.5rem); }
  .fig-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: clamp(1rem, 2.5vw, 1.4rem); }

  .refs { margin-bottom: clamp(2.5rem, 5vw, 3.5rem); }
  .ref-list { counter-reset: ref; list-style: none; display: flex; flex-direction: column; gap: 1rem; max-width: 82ch; }
  .ref-list li { display: grid; grid-template-columns: 1.9rem 1fr; gap: 0.5rem; }
  .ref-list li::before {
    counter-increment: ref;
    content: counter(ref) ".";
    color: var(--accent);
    font-variant-numeric: tabular-nums;
    font-size: 0.9rem;
    padding-top: 0.15rem;
  }
  .r-title { font-size: 1rem; font-weight: 500; line-height: 1.4; color: var(--ink); }
  .r-title a { color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--line); transition: color 0.18s, border-color 0.18s; }
  .r-title a:hover, .r-title a:focus-visible { color: var(--accent); border-color: var(--accent); outline: none; }
  .r-meta { color: var(--muted); font-size: 0.9rem; margin-top: 0.15rem; }
  .r-venue { font-style: italic; }
</style>
